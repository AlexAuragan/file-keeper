#!/bin/bash

NODES_FILE="$HOME/.fkg_nodes"

gather_node() {
	local node="$1"          # display name, used for folder and local check
	local target="${2:-$1}"  # SSH target (IP or hostname)
	local cache_dir="/cache/file_keeper/$node"
	local lxc_base="/var/lib/lxc"
	local is_local=false
	[ "$node" = "$(hostname)" ] && is_local=true

	echo "=== $node ==="

	local ct_ids
	if $is_local; then
		if ! command -v pct &>/dev/null; then
			echo "  Error: pct not found. This command must run on a Proxmox host."
			return 1
		fi
		ct_ids=$(pct list 2>/dev/null | awk 'NR>1 {print $1}')
	else
		ct_ids=$(ssh "$target" "pct list 2>/dev/null | awk 'NR>1 {print \$1}'" 2>/dev/null)
	fi

	if [ -z "$ct_ids" ]; then
		echo "  No containers found."
		return 1
	fi

	for ctid in $ct_ids; do
		echo "  CT $ctid:"

		local status
		if $is_local; then
			status=$(pct status "$ctid" 2>/dev/null | awk '{print $2}')
		else
			status=$(ssh "$target" "pct status $ctid 2>/dev/null | awk '{print \$2}'" 2>/dev/null)
		fi

		local ct_db_content=""
		if $is_local; then
			if [ "$status" = "running" ]; then
				ct_db_content=$(pct exec "$ctid" -- cat /root/.file_keeper 2>/dev/null)
			else
				local ct_db="$lxc_base/$ctid/rootfs/root/.file_keeper"
				[ -f "$ct_db" ] && ct_db_content=$(cat "$ct_db")
			fi
		else
			if [ "$status" = "running" ]; then
				ct_db_content=$(ssh "$target" "pct exec $ctid -- cat /root/.file_keeper 2>/dev/null" 2>/dev/null)
			else
				ct_db_content=$(ssh "$target" "cat $lxc_base/$ctid/rootfs/root/.file_keeper 2>/dev/null" 2>/dev/null)
			fi
		fi

		if [ -z "$ct_db_content" ]; then
			echo "    skipped (fk not installed or no files tracked)"
			continue
		fi

		local dest="$cache_dir/CT$ctid"

		while IFS= read -r line; do
			local path="${line%%|*}"
			[ -z "$path" ] && continue
			local dest_file="$dest$path"
			mkdir -p "$(dirname "$dest_file")"

			local ok=false
			if $is_local; then
				if [ "$status" = "running" ]; then
					pct exec "$ctid" -- cat "$path" >"$dest_file" 2>/dev/null && ok=true
				else
					cp "$lxc_base/$ctid/rootfs$path" "$dest_file" 2>/dev/null && ok=true
				fi
			else
				if [ "$status" = "running" ]; then
					ssh -n "$target" "pct exec $ctid -- cat $path" >"$dest_file" 2>/dev/null && ok=true
				else
					ssh -n "$target" "cat $lxc_base/$ctid/rootfs$path" >"$dest_file" 2>/dev/null && ok=true
				fi
			fi

			if $ok && [ -s "$dest_file" ]; then
				echo "    $path"
			else
				rm -f "$dest_file"
				echo "    $path (failed)"
			fi
		done <<<"$ct_db_content"
	done
}

lookup_target() {
	local name="$1"
	local ip
	ip=$(grep -m1 "^$name " "$NODES_FILE" 2>/dev/null | awk '{print $2}')
	echo "${ip:-$name}"
}

nodes_add() {
	local name="$1"
	local ip="$2"

	if [ -z "$name" ]; then
		echo "Usage: fkg proxmox --add <name> [ip]"
		return 1
	fi

	if grep -qE "^$name( |$)" "$NODES_FILE" 2>/dev/null; then
		echo "Node already exists: $name"
		return 1
	fi

	touch "$NODES_FILE"
	if [ -n "$ip" ]; then
		echo "$name $ip" >>"$NODES_FILE"
		echo "Added: $name ($ip)"
	else
		echo "$name" >>"$NODES_FILE"
		echo "Added: $name"
	fi
}

gather_proxmox() {
	shift  # remove 'proxmox' from args

	if [ "$1" = "--add" ]; then
		shift
		nodes_add "$@"
		return
	fi

	local names=()
	local targets=()

	if [ $# -gt 0 ]; then
		for name in "$@"; do
			names+=("$name")
			targets+=("$(lookup_target "$name")")
		done
	elif [ -f "$NODES_FILE" ]; then
		while IFS= read -r line; do
			[[ -z "$line" || "$line" == \#* ]] && continue
			local name="${line%% *}"
			local ip="${line#* }"
			[ "$ip" = "$name" ] && ip=""
			names+=("$name")
			targets+=("${ip:-$name}")
		done <"$NODES_FILE"
		if [ ${#names[@]} -eq 0 ]; then
			echo "No nodes found in $NODES_FILE."
			return 1
		fi
	else
		echo "No nodes specified and $NODES_FILE not found."
		echo "Add a node with: fkg proxmox --add <name> [ip]"
		return 1
	fi

	for i in "${!names[@]}"; do
		gather_node "${names[$i]}" "${targets[$i]}"
	done
}

update() {
	local base_url="https://forgejo.auragan.fr/AlexAuragan/file-keeper/raw/branch/main"
	local version_path="/usr/local/bin/.version"

	local remote_version
	remote_version=$(curl -sSL "$base_url/.version") || { echo "Failed to fetch version info."; return 1; }

	local local_version
	local_version=$(cat "$version_path" 2>/dev/null)

	if [ "$remote_version" = "$local_version" ]; then
		echo "Already up to date ($remote_version)."
		return 0
	fi

	echo "Updating $local_version -> $remote_version..."

	for bin in fk fkg; do
		local tmp
		tmp=$(mktemp)
		curl -sSL "$base_url/$bin" -o "$tmp" || { echo "Failed to download $bin."; rm -f "$tmp"; return 1; }
		chmod +x "$tmp"
		local dest="/usr/local/bin/$bin"
		if [ -w "$(dirname "$dest")" ]; then
			mv "$tmp" "$dest"
		elif command -v sudo >/dev/null 2>&1; then
			sudo mv "$tmp" "$dest"
		else
			echo "Error: cannot write to $(dirname "$dest") and sudo is unavailable."
			rm -f "$tmp"
			return 1
		fi
		echo "  $bin updated."
	done

	local tmp_ver
	tmp_ver=$(mktemp)
	echo "$remote_version" >"$tmp_ver"
	if [ -w "$(dirname "$version_path")" ]; then
		mv "$tmp_ver" "$version_path"
	else
		sudo mv "$tmp_ver" "$version_path"
	fi

	echo "Done. fk $remote_version installed."
}

show_help() {
	echo "fkg - file keeper gatherer"
	echo ""
	echo "Usage: fkg <command> [args]"
	echo ""
	echo "  proxmox                      Gather from all nodes in ~/.fkg_nodes"
	echo "  proxmox <node...>            Gather from specific nodes (looks up IP from config)"
	echo "  proxmox --add <name> [ip]    Register a node"
	echo ""
	echo "  --update                     Update fk and fkg to the latest version"
	echo "  --help                       Show this help message"
	echo ""
	echo "Node resolution:"
	echo "  Nodes matching \$(hostname) are gathered locally via pct."
	echo "  All other nodes are reached via SSH using their configured IP."
	echo ""
	echo "Output: /cache/file_keeper/<node>/CT<id>/<path>"
	echo ""
	echo "Config: ~/.fkg_nodes — one entry per line: <name> [ip]"
}

case "$1" in
proxmox) gather_proxmox "$@" ;;
--update) update ;;
--help) show_help ;;
*)
	show_help
	;;
esac
