#!/bin/bash

NODES_FILE="$HOME/.fg_nodes"

gather_node() {
	local node="$1"
	local cache_dir="/cache/file_keeper/$node"
	local lxc_base="/var/lib/lxc"
	local is_local=false
	[ "$node" = "$(hostname)" ] && is_local=true

	echo "=== $node ==="

	local ct_ids
	if $is_local; then
		if ! command -v pct &>/dev/null; then
			echo "  Error: pct not found. This command must run on a Proxmox host."
			return 1
		fi
		ct_ids=$(pct list 2>/dev/null | awk 'NR>1 {print $1}')
	else
		ct_ids=$(ssh "$node" "pct list 2>/dev/null | awk 'NR>1 {print \$1}'" 2>/dev/null)
	fi

	if [ -z "$ct_ids" ]; then
		echo "  No containers found."
		return 1
	fi

	for ctid in $ct_ids; do
		echo "  CT $ctid:"

		local status
		if $is_local; then
			status=$(pct status "$ctid" 2>/dev/null | awk '{print $2}')
		else
			status=$(ssh "$node" "pct status $ctid 2>/dev/null | awk '{print \$2}'" 2>/dev/null)
		fi

		local ct_db_content=""
		if $is_local; then
			if [ "$status" = "running" ]; then
				ct_db_content=$(pct exec "$ctid" -- cat /root/.file_keeper 2>/dev/null)
			else
				local ct_db="$lxc_base/$ctid/rootfs/root/.file_keeper"
				[ -f "$ct_db" ] && ct_db_content=$(cat "$ct_db")
			fi
		else
			if [ "$status" = "running" ]; then
				ct_db_content=$(ssh "$node" "pct exec $ctid -- cat /root/.file_keeper 2>/dev/null" 2>/dev/null)
			else
				ct_db_content=$(ssh "$node" "cat $lxc_base/$ctid/rootfs/root/.file_keeper 2>/dev/null" 2>/dev/null)
			fi
		fi

		if [ -z "$ct_db_content" ]; then
			echo "    skipped (fk not installed or no files tracked)"
			continue
		fi

		local dest="$cache_dir/CT$ctid"

		while IFS= read -r line; do
			local path="${line%%|*}"
			[ -z "$path" ] && continue
			local dest_file="$dest$path"
			mkdir -p "$(dirname "$dest_file")"

			local ok=false
			if $is_local; then
				if [ "$status" = "running" ]; then
					pct exec "$ctid" -- cat "$path" >"$dest_file" 2>/dev/null && ok=true
				else
					cp "$lxc_base/$ctid/rootfs$path" "$dest_file" 2>/dev/null && ok=true
				fi
			else
				if [ "$status" = "running" ]; then
					ssh "$node" "pct exec $ctid -- cat $path" >"$dest_file" 2>/dev/null && ok=true
				else
					ssh "$node" "cat $lxc_base/$ctid/rootfs$path" >"$dest_file" 2>/dev/null && ok=true
				fi
			fi

			if $ok && [ -s "$dest_file" ]; then
				echo "    $path"
			else
				rm -f "$dest_file"
				echo "    $path (failed)"
			fi
		done <<<"$ct_db_content"
	done
}

gather_proxmox() {
	shift  # remove 'proxmox' from args
	local nodes=()

	if [ $# -gt 0 ]; then
		nodes=("$@")
	elif [ -f "$NODES_FILE" ]; then
		while IFS= read -r line; do
			[[ -z "$line" || "$line" == \#* ]] && continue
			nodes+=("$line")
		done <"$NODES_FILE"
		if [ ${#nodes[@]} -eq 0 ]; then
			echo "No nodes found in $NODES_FILE."
			return 1
		fi
	else
		echo "No nodes specified and $NODES_FILE not found."
		echo "Create $NODES_FILE with one node per line, or pass node names as arguments."
		return 1
	fi

	for node in "${nodes[@]}"; do
		gather_node "$node"
	done
}

update() {
	local base_url="https://raw.githubusercontent.com/AlexAuragan/file-keeper/main"
	local version_path="/usr/local/bin/.version"

	local remote_version
	remote_version=$(curl -sSL "$base_url/.version") || { echo "Failed to fetch version info."; return 1; }

	local local_version
	local_version=$(cat "$version_path" 2>/dev/null)

	if [ "$remote_version" = "$local_version" ]; then
		echo "Already up to date ($remote_version)."
		return 0
	fi

	echo "Updating $local_version -> $remote_version..."

	for bin in fk fg; do
		local tmp
		tmp=$(mktemp)
		curl -sSL "$base_url/$bin" -o "$tmp" || { echo "Failed to download $bin."; rm -f "$tmp"; return 1; }
		chmod +x "$tmp"
		local dest="/usr/local/bin/$bin"
		if [ -w "$(dirname "$dest")" ]; then
			mv "$tmp" "$dest"
		elif command -v sudo >/dev/null 2>&1; then
			sudo mv "$tmp" "$dest"
		else
			echo "Error: cannot write to $(dirname "$dest") and sudo is unavailable."
			rm -f "$tmp"
			return 1
		fi
		echo "  $bin updated."
	done

	local tmp_ver
	tmp_ver=$(mktemp)
	echo "$remote_version" >"$tmp_ver"
	if [ -w "$(dirname "$version_path")" ]; then
		mv "$tmp_ver" "$version_path"
	else
		sudo mv "$tmp_ver" "$version_path"
	fi

	echo "Done. fk $remote_version installed."
}

show_help() {
	echo "fg - file gatherer"
	echo ""
	echo "Usage: fg <command> [args]"
	echo ""
	echo "  proxmox              Gather from all nodes listed in ~/.fg_nodes"
	echo "  proxmox <node...>    Gather from specific nodes"
	echo ""
	echo "  --update             Update fk and fg to the latest version"
	echo "  --help               Show this help message"
	echo ""
	echo "Node resolution:"
	echo "  Nodes matching \$(hostname) are gathered locally via pct."
	echo "  All other nodes are reached via SSH."
	echo ""
	echo "Output: /cache/file_keeper/<node>/CT<id>/<path>"
	echo ""
	echo "Config: ~/.fg_nodes — one node hostname per line, # for comments"
}

case "$1" in
proxmox) gather_proxmox "$@" ;;
--update) update ;;
--help) show_help ;;
*)
	show_help
	;;
esac
